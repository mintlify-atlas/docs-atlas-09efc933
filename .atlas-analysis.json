  "keyFeatures": [
    "Provider-agnostic: works with Claude, Gemini, Codex, OpenCode, Ollama, LM Studio, and GitHub Models",
    "Zero dependencies: pure Bash, no Node/Python/Go required",
    "Git-native integration via pre-commit and commit-msg hooks",
    "Smart file caching to skip unchanged files and speed up reviews",
    "PR review mode to review entire pull request diffs",
    "CI/CD support with --ci flag for GitHub Actions and GitLab CI",
    "Configurable file patterns and exclusion rules",
    "Skill-based AGENTS.md approach for large or multi-stack projects",
    "Cross-platform: macOS, Linux, Windows (Git Bash), WSL"
  ],
  "publicApiSurface": [
